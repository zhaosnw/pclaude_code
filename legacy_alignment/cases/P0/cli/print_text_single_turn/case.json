{
  "case_id": "cli.print.text_single_turn",
  "priority": "P0",
  "modules": [
    "cli/print.ts",
    "hare/cli/print_handler.py",
    "hare/cli/structured_io.py",
    "hare/entrypoints/cli.py",
    "hare/main.py",
    "hare/query/core.py"
  ],
  "description": "Print mode returns text output from model response",
  "entrypoint": {
    "kind": "query"
  },
  "env": {
    "TZ": "UTC",
    "LANG": "C.UTF-8"
  },
  "mocks": {
    "model": {
      "turns": [
        {
          "stop_reason": "end_turn",
          "content": [
            {
              "type": "text",
              "text": "Hello! How can I help you today?"
            }
          ]
        }
      ]
    },
    "network": "deny",
    "subprocess": "deny",
    "max_turns": 5
  },
  "expected": {
    "exit_code": 0,
    "stdout_kind": "text"
  },
  "policy": {
    "ignore_fields": [],
    "tolerance": {
      "events.1.event.usage.output_tokens": "+/-10"
    },
    "blocking": true,
    "allow_delta": [
      {
        "path": "stdout",
        "reason": "Phase 2: stdout format, content matches",
        "expires_at": "2099-01-01",
        "kind": "text"
      }
    ]
  }
}